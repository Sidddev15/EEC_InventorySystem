# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/eec_inventory?schema=public"

# Auth
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"

# Initial production admin seed
ADMIN_EMAIL="admin@eec.local"
ADMIN_PASSWORD="replace-before-production"
ADMIN_NAME="EEC Admin"

# AI helper provider. Groq is OpenAI-compatible.
AI_API_KEY=""
AI_MODEL="llama-3.1-8b-instant"
AI_BASE_URL="https://api.groq.com/openai/v1"
